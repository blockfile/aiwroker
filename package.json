{
  "name": "aiworker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CPU-first decentralized inference network: an orchestrator that routes chat jobs to volunteer worker machines and streams tokens back.",
  "engines": {
    "node": ">=20"
  },
  "bin": {
