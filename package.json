    "worker": "node src/workers/native-worker.js",
    "worker:mock": "node src/workers/mock-worker.js",
    "test": "node --test"
  },
  "dependencies": {
    "express": "^4.19.2",
    "mongodb": "^6.10.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5"
  }
}
