# --- Orchestrator ---
# Port the orchestrator listens on (HTTP + WebSocket)
PORT=3000

# Seconds to wait for the FIRST token from a worker before treating the job as
# stalled and reassigning it. CPU workers spend real time reading the prompt
# before the first token, so keep this generous.
FIRST_TOKEN_TIMEOUT_S=90

# Seconds of silence AFTER streaming has started before a job is treated as
# stalled (worker died mid-answer).
STREAM_STALL_TIMEOUT_S=30

# How many times a single job may be reassigned to a new worker before failing.
MAX_RETRIES=2

# --- Reward system (optional) ---
# MongoDB Atlas connection string. Leave empty to run WITHOUT persistence — the
# orchestrator works the same, it just won't record contributions/rewards.
MONGODB_URI=
MONGODB_DB=core

# --- Branding ---
# Your product name. The model will present itself as this instead of the
# underlying vendor (e.g. "Qwen / Alibaba").
BRAND_NAME=AIworker
# Optional: replace the entire identity/system prompt. Leave unset to use the
# branded default built from BRAND_NAME. Set to an empty value to disable
# identity injection entirely.
# SYSTEM_PROMPT=You are AIworker, a helpful assistant. ...

# --- Worker (native + mock) ---
# Where the worker connects. Use your droplet's public URL in production.
ORCH=http://localhost:3000

# Native worker: which Ollama model to serve, and where Ollama listens.
MODEL=qwen2.5:1.5b
OLLAMA_URL=http://localhost:11434

# Optional friendly name shown in /stats and to users.
WORKER_NAME=
